# Base URL of the API (no trailing slash)
VITE_API_URL=http://127.0.0.1:4000

# Optional override for QR link base (default: current site origin, or https://burqan.store at build time).
# Store / card QRs encode: {base}/r/{token} → owner portal in the phone browser.
# VITE_QR_PAYLOAD_BASE_URL=https://burqan.store
