{
  "expo": {
    "name": "برقان — المندوب",
    "slug": "mobile",
    "version": "1.0.6",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/burqanlogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Burqan to scan store QR codes and take store photos.",
        "NSPhotoLibraryUsageDescription": "Allow Burqan to choose store photos from your gallery.",
        "NSLocationWhenInUseUsageDescription": "Burqan uses your location to register stores, verify you are at the store, and assign the correct area.",
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        },
        "UISupportedInterfaceOrientations": [
          "UIInterfaceOrientationPortrait"
        ],
        "UISupportedInterfaceOrientations~ipad": [
          "UIInterfaceOrientationLandscapeLeft",
          "UIInterfaceOrientationLandscapeRight",
          "UIInterfaceOrientationPortrait"
        ]
      }
    },
    "android": {
      "package": "com.burqan.rep",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Burqan to scan store QR codes."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Burqan uses your location to register stores and verify you are at the store."
        }
      ],
      "expo-font"
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "999b33f2-9d7c-434e-ac20-e13804429120"
      }
    },
    "owner": "saeedfwaz"
  }
}
