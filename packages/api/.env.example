DATABASE_URL=postgresql://burqan:burqan@127.0.0.1:15433/burqan
JWT_ADMIN_SECRET=replace_with_long_random_string_at_least_32_chars
JWT_REP_SECRET=replace_with_different_long_random_string_32_plus
PORT=4000
# Bind on all interfaces so phones on Wi‑Fi can reach the API (default). Use 127.0.0.1 only if you intentionally block LAN.
LISTEN_HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8081,https://burqan.store,https://www.burqan.store
BCRYPT_ROUNDS=12
OWNER_PORTAL_BASE_URL=https://burqan.store
QR_PAYLOAD_BASE_URL=https://burqan.store

# Max distance (meters) from store for rep QR scan, visit, and order (default 5000 = 5 km)
# SCAN_MAX_DISTANCE_M=5000

# Optional seed overrides
# SEED_SUPER_EMAIL=super@burqan.store
# SEED_SUPER_PASSWORD=...
# SEED_REP_EMAIL=rep@burqan.store
# SEED_REP_PASSWORD=...

# Google Maps — Geocoding + Places (import grocery/supermarket listings from Google Maps)
# Enable Geocoding API and Places API on the same key in Google Cloud Console.
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Local QR pool size (default 6000)
# QR_POOL_TARGET=100

# Admin password reset (dashboard links + Gmail SMTP)
# DASHBOARD_BASE_URL=https://burqan.store
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_gmail_app_password_no_spaces
# SMTP_FROM=your@gmail.com
# ADMIN_RESET_TOKEN_MINUTES=60

# One-off super admin (run: npm run api:create-super-admin — do not commit passwords)
# SUPER_ADMIN_EMAIL=
# SUPER_ADMIN_PASSWORD=
# SUPER_ADMIN_NAME=
