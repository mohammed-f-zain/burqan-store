{
  "name": "burqan-store",
  "private": true,
  "workspaces": [
    "packages/api",
    "packages/dashboard",
    "packages/mobile"
  ],
  "scripts": {
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "api:dev": "npm run dev -w @burqan/api",
    "api:build": "npm run build -w @burqan/api",
    "api:migrate": "npm run migrate -w @burqan/api",
    "api:migrate:geo": "npm run migrate:geo -w @burqan/api",
    "api:seed": "npm run seed -w @burqan/api",
    "api:seed:jordan-areas": "npm run seed:jordan-areas -w @burqan/api",
    "api:reset:commerce": "npm run reset:commerce -w @burqan/api",
    "api:gen:qr": "npm run gen:qr -w @burqan/api",
    "api:reset-admin": "npm run reset-admin -w @burqan/api",
    "api:migrate:auth": "npm run migrate:auth -w @burqan/api",
    "api:migrate:all": "npm run migrate:all -w @burqan/api",
    "api:create-super-admin": "npm run create-super-admin -w @burqan/api",
    "dashboard:dev": "npm run dev -w @burqan/dashboard",
    "mobile:start": "npm run start -w mobile"
  },
  "engines": {
    "node": ">=20"
  }
}
